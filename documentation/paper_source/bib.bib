@incollection{wundsch2016railway,
    author = {Wündsch, Björn},
    isbn = {9780198713418},
    title = {Railway Financing: {Europe} in the Nineteenth Century},
    booktitle = {Infrastructure Finance in Europe: Insights into the History of Water, Transport, and Telecommunications},
    publisher = {Oxford University Press},
    year = {2016},
    month = {01},
    abstract = {The development of a transnational European railway system is on the political agenda within the European Union today. The aim of this chapter is to look into the past and describe cases based the development of the railway networks one finds in the present, from local industry-based lines to small trans-regional networks initiated by the private sector. This was followed by strategic and welfare thoughts placed on the political agenda to create national networks. The importance of railway networks on the political agenda changed over time and had an impact on how to finance railway projects. This chapter will attempt to answer and derive patterns to a central question, which is: when, why, and how did railway infrastructure became part of the political agenda in European countries?},
    doi = {10.1093/acprof:oso/9780198713418.003.0010},
    url = {https://doi.org/10.1093/acprof:oso/9780198713418.003.0010},
    eprint = {https://academic.oup.com/book/0/chapter/144266867/chapter-ag-pdf/45015127/book\_3273\_section\_144266867.ag.pdf},
}

